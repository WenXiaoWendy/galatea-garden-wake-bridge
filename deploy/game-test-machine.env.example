# 由游戏测试机自己的 Codex app-server 持有目标任务。
CODEX_APP_SERVER_URL=ws://127.0.0.1:8765
CODEX_THREAD_ID=替换为游戏测试任务ID
# 仅在 app-server 启用了 WebSocket 鉴权时设置：
# CODEX_APP_SERVER_TOKEN=替换为本机app-server令牌
CODEX_INJECTOR_TIMEOUT_MS=15000

# 桥调用 Node.js 注入器。Windows 可把 node 改为 node.exe。
GARDEN_INJECTOR_EXECUTABLE=node
GARDEN_INJECTOR_ARGS_JSON='["/绝对路径/galatea-garden-wake-bridge/integrations/codex-app-server/inject.mjs"]'
GARDEN_INJECTOR_WORKING_DIRECTORY=/绝对路径/galatea-garden-wake-bridge
